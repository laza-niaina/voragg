<Window x:Class="AnimeDownloader.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:AnimeDownloader"
        Title="VoraGG Downloader" Height="760" Width="1100"
        Icon="pack://application:,,,/voragg-app-icon.jpg"
        WindowStartupLocation="CenterScreen"
        Background="#09090B"
        Foreground="#F5F7FA"
        FontFamily="Inter, Segoe UI"
        Loaded="Window_Loaded">

    <Window.Resources>
        <!-- Brushes — VoraGG Modern Palette -->
        <SolidColorBrush x:Key="BgPrimary" Color="#09090B"/>
        <SolidColorBrush x:Key="BgSecondary" Color="#111122"/>
        <SolidColorBrush x:Key="BgTertiary" Color="#1A1A2E"/>
        <SolidColorBrush x:Key="ZoneHover" Color="#25253D"/>
        <SolidColorBrush x:Key="BorderBrush" Color="#2D2D4A"/>
        <SolidColorBrush x:Key="BorderGlass" Color="#3D3D6B"/>
        <SolidColorBrush x:Key="AccentPurple" Color="#7C3AED"/>
        <SolidColorBrush x:Key="AccentBlue" Color="#3B82F6"/>
        <SolidColorBrush x:Key="CyanGlow" Color="#22D3EE"/>
        <SolidColorBrush x:Key="TextPrimary" Color="#F5F7FA"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#9CA3AF"/>
        <SolidColorBrush x:Key="TextTertiary" Color="#6B7280"/>
        <SolidColorBrush x:Key="TextAccent" Color="#7C3AED"/>
        <SolidColorBrush x:Key="Success" Color="#10B981"/>
        <SolidColorBrush x:Key="Error" Color="#EF4444"/>
        <SolidColorBrush x:Key="Warning" Color="#F59E0B"/>

        <!-- Accent hover variant -->
        <SolidColorBrush x:Key="AccentHover" Color="#6535C5"/>

        <!-- Primary Button — solid purple -->
        <Style TargetType="Button" x:Key="PrimaryButton">
            <Setter Property="Background" Value="#7C3AED"/>
            <Setter Property="Foreground" Value="#F5F7FA"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="20 10"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Name="Root" Background="{TemplateBinding Background}"
                                BorderThickness="0" CornerRadius="10"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#6535C5"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Root" Property="Background" Value="#1A1A2E"/>
                                <Setter Property="Foreground" Value="#6B7280"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Secondary Button — glass style -->
        <Style TargetType="Button" x:Key="SecondaryButton">
            <Setter Property="Background" Value="#1A1A2E"/>
            <Setter Property="Foreground" Value="#F5F7FA"/>
            <Setter Property="BorderBrush" Value="#2D2D4A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="14 6"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Name="Root" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#25253D"/>
                                <Setter TargetName="Root" Property="BorderBrush" Value="#7C3AED"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#1A1A3E"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Danger Button — red glass -->
        <Style TargetType="Button" x:Key="DangerButton">
            <Setter Property="Background" Value="#1A1A2E"/>
            <Setter Property="Foreground" Value="#EF4444"/>
            <Setter Property="BorderBrush" Value="#EF4444"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="14 6"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Name="Root" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#2D1520"/>
                                <Setter TargetName="Root" Property="BorderBrush" Value="#F87171"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#3D1520"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- TextBox — glass input -->
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#111122"/>
            <Setter Property="Foreground" Value="#F5F7FA"/>
            <Setter Property="BorderBrush" Value="#2D2D4A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8 6"/>
            <Setter Property="CaretBrush" Value="#7C3AED"/>
            <Setter Property="FontSize" Value="13"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="BorderBrush" Value="#3D3D6B"/>
                </Trigger>
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="BorderBrush" Value="#7C3AED"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ComboBox -->
        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="#1A1A2E"/>
            <Setter Property="Foreground" Value="#F5F7FA"/>
            <Setter Property="BorderBrush" Value="#3D3D6B"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10 7"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border Name="Border" Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="6" Padding="{TemplateBinding Padding}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <ContentPresenter Grid.Column="0" Content="{TemplateBinding SelectionBoxItem}"
                                                      ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                      ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                                      VerticalAlignment="Center"
                                                      Margin="0 0 6 0"/>
                                    <TextBlock Grid.Column="1" Text="▾" Foreground="#7C3AED"
                                               FontSize="10" VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                            <Popup Name="Popup" Placement="Bottom"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   PopupAnimation="Slide">
                                <Border Name="DropDownBorder" Background="#1A1A2E"
                                        BorderBrush="#3D3D6B" BorderThickness="1"
                                        CornerRadius="6" MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                    <ScrollViewer>
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="BorderBrush" Value="#7C3AED"/>
                            </Trigger>
                            <Trigger Property="IsDropDownOpen" Value="True">
                                <Setter TargetName="Border" Property="BorderBrush" Value="#7C3AED"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ComboBoxItem -->
        <Style TargetType="ComboBoxItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#F5F7FA"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10 7"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Normal"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#25253D"/>
                    <Setter Property="Foreground" Value="#FFFFFF"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#1E1040"/>
                    <Setter Property="Foreground" Value="#7C3AED"/>
                    <Setter Property="FontWeight" Value="SemiBold"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Foreground" Value="#6B7280"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- TabItem -->
        <Style TargetType="TabItem">
            <Setter Property="Background" Value="#111122"/>
            <Setter Property="Foreground" Value="#9CA3AF"/>
            <Setter Property="BorderBrush" Value="#2D2D4A"/>
            <Setter Property="Padding" Value="24 12"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Grid>
                            <Border Name="Border" Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="1 1 1 0"
                                    CornerRadius="12 12 0 0"
                                    Padding="{TemplateBinding Padding}"
                                    Margin="0 0 -1 0">
                                <ContentPresenter Content="{TemplateBinding Header}"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
                            </Border>
                            <!-- Active indicator bar -->
                            <Rectangle Name="ActiveBar" Height="2" VerticalAlignment="Bottom"
                                       Fill="{StaticResource AccentPurple}" Opacity="0"
                                       Margin="8 0"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#09090B"/>
                                <Setter TargetName="Border" Property="BorderThickness" Value="1 1 1 0"/>
                                <Setter Property="Foreground" Value="#7C3AED"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter TargetName="ActiveBar" Property="Opacity" Value="1"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="#F5F7FA"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ListView -->
        <Style TargetType="ListView">
            <Setter Property="Background" Value="#09090B"/>
            <Setter Property="Foreground" Value="#F5F7FA"/>
            <Setter Property="BorderBrush" Value="#2D2D4A"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>

        <Style TargetType="ListViewItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#F5F7FA"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="6 4"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1A1A2E"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#1E1040"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ScrollViewer -->
        <Style TargetType="ScrollViewer">
            <Setter Property="Background" Value="#09090B"/>
            <Setter Property="BorderBrush" Value="#2D2D4A"/>
        </Style>

        <!-- StatusBar -->
        <Style TargetType="StatusBar">
            <Setter Property="Background" Value="#111122"/>
            <Setter Property="Foreground" Value="#9CA3AF"/>
            <Setter Property="BorderBrush" Value="#2D2D4A"/>
        </Style>

        <!-- ProgressBar -->
        <Style TargetType="ProgressBar">
            <Setter Property="Background" Value="#2D2D4A"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height" Value="6"/>
            <Setter Property="Minimum" Value="0"/>
            <Setter Property="Maximum" Value="100"/>
            <Setter Property="Foreground" Value="{StaticResource AccentPurple}"/>
        </Style>

        <!-- ============ Data Templates ============ -->

        <!-- Episode Row inside a Job Card -->
        <DataTemplate x:Key="EpisodeRowTemplate">
            <Grid Margin="0 2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="{Binding DisplayText}"
                           Foreground="#F5F7FA" FontSize="12"
                           VerticalAlignment="Center"
                           Grid.Column="0" Margin="0 0 8 0"/>

                <ProgressBar Value="{Binding ProgressPercent}"
                             VerticalAlignment="Center"
                             Grid.Column="1" Margin="0 0 8 0">
                    <ProgressBar.Style>
                        <Style TargetType="ProgressBar">
                            <Setter Property="Foreground" Value="{StaticResource AccentPurple}"/>
                            <Setter Property="Background" Value="#2D2D4A"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Height" Value="4"/>
                            <Setter Property="Minimum" Value="0"/>
                            <Setter Property="Maximum" Value="100"/>
                            <Setter Property="IsIndeterminate" Value="False"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Status}" Value="fetching">
                                    <Setter Property="IsIndeterminate" Value="True"/>
                                    <Setter Property="Foreground" Value="{StaticResource AccentBlue}"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Status}" Value="completed">
                                    <Setter Property="Foreground" Value="#10B981"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Status}" Value="error">
                                    <Setter Property="Foreground" Value="#EF4444"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Status}" Value="skipped">
                                    <Setter Property="Foreground" Value="#F59E0B"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ProgressBar.Style>
                </ProgressBar>

                <TextBlock Text="{Binding SizeText}"
                           Foreground="#9CA3AF" FontSize="11"
                           VerticalAlignment="Center"
                           Grid.Column="2" Margin="0 0 8 0"/>

                <TextBlock Text="{Binding StatusDisplayText}"
                           Foreground="#9CA3AF" FontSize="11"
                           VerticalAlignment="Center"
                           Grid.Column="3" Margin="0 0 8 0"/>

                <Button Content="🗑" Width="26" Height="26"
                        FontSize="11" Padding="0"
                        Background="#1A1A2E" Foreground="#F5F7FA"
                        BorderThickness="1" BorderBrush="#2D2D4A"
                        Grid.Column="4"
                        Visibility="{Binding ShowDelete}"
                        Click="DeleteEpisode_Click"/>
            </Grid>
        </DataTemplate>

        <!-- Job Card -->
        <DataTemplate x:Key="JobCardTemplate">
            <Border Background="#111122" BorderBrush="#2D2D4A"
                    BorderThickness="1" CornerRadius="14" Padding="16"
                    Margin="0 0 0 12">
                <StackPanel>
                    <!-- Header -->
                    <Grid Margin="0 0 0 8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Orientation="Horizontal" Grid.Column="0">
                            <TextBlock Text="{Binding JobDisplayId}"
                                       Foreground="#7C3AED" FontWeight="Bold" FontSize="13"
                                       VerticalAlignment="Center"/>
                            <Rectangle Width="1" Fill="#2D2D4A" Margin="8 2"/>
                            <TextBlock Text="{Binding Status}"
                                       Foreground="{Binding StatusBrush}" FontSize="12"
                                       VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding ProgressText}"
                                       Foreground="#9CA3AF" FontSize="12"
                                       VerticalAlignment="Center" Margin="8 0 0 0"/>
                        </StackPanel>

                        <Button Content="Cancel"
                                Style="{StaticResource SecondaryButton}"
                                Grid.Column="1" Margin="0 0 6 0"
                                Visibility="{Binding ShowCancel}"
                                Click="CancelJob_Click"/>

                        <Button Content="Clear"
                                Style="{StaticResource SecondaryButton}"
                                Grid.Column="2" Margin="0 0 6 0"
                                Visibility="{Binding ShowClear}"
                                Click="ClearJob_Click"/>

                        <Button Content="Delete All Files"
                                Style="{StaticResource DangerButton}"
                                Grid.Column="3"
                                Visibility="{Binding ShowDeleteAll}"
                                Click="DeleteAllFiles_Click"/>
                    </Grid>

                    <!-- Separator -->
                    <Rectangle Fill="#2D2D4A" Height="1" Margin="0 0 0 8" Opacity="0.5"/>

                    <!-- Episodes -->
                    <ItemsControl ItemsSource="{Binding Episodes}"
                                  ItemTemplate="{StaticResource EpisodeRowTemplate}"/>
                </StackPanel>
            </Border>
        </DataTemplate>
    </Window.Resources>

    <!-- ============ Main Layout ============ -->
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#111122"
                BorderBrush="#2D2D4A" BorderThickness="0 0 0 1">
            <StackPanel Orientation="Horizontal" Margin="20 14">
                <TextBlock Text="VoraGG" Foreground="#7C3AED"
                           FontSize="22" FontWeight="Bold" VerticalAlignment="Center"/>
                <TextBlock Text="Downloader" Foreground="#22D3EE" FontSize="22"
                           FontWeight="Bold" Margin="6 0 0 0" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Content -->
        <TabControl x:Name="MainTabControl" Grid.Row="1"
                    Background="#09090B" BorderThickness="0"
                    TabStripPlacement="Top"
                    SelectionChanged="TabControl_SelectionChanged">

            <!-- ===== Browse Tab ===== -->
            <TabItem Header="Browse">
                <Grid Margin="16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- URL row -->
                    <Border Grid.Row="0" Background="#111122" BorderBrush="#2D2D4A"
                            BorderThickness="1" CornerRadius="12" Padding="14" Margin="0 0 0 10">
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBox x:Name="UrlTextBox" Grid.Column="0"
                                     Padding="10 8" FontSize="13"
                                     Text="https://voir-anime.to/..." />
                            <Button x:Name="FetchButton" Grid.Column="1" Margin="8 0 0 0"
                                    Content="Fetch" Style="{StaticResource PrimaryButton}"
                                    Width="110" Click="FetchButton_Click"/>
                        </Grid>
                    </Border>

                    <!-- Options row -->
                    <Border x:Name="OptionsPanel" Grid.Row="1"
                            Background="#111122" BorderBrush="#2D2D4A"
                            BorderThickness="1" CornerRadius="12" Padding="14"
                            Margin="0 0 0 10" IsEnabled="False">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <!-- Row 0: Player + Quality -->
                            <StackPanel Orientation="Horizontal" Grid.Row="0" Grid.Column="0" Margin="0 0 0 8">
                                <TextBlock Text="Player:" Foreground="#9CA3AF"
                                           VerticalAlignment="Center" Margin="0 0 8 0"/>
                                <ComboBox x:Name="PlayerCombo" SelectedIndex="0" Width="130"
                                          Margin="0 0 24 0">
                                    <ComboBoxItem Content="streamtape"/>
                                    <ComboBoxItem Content="mytv"/>
                                    <ComboBoxItem Content="videosaba"/>
                                </ComboBox>
                                <TextBlock Text="Quality:" Foreground="#9CA3AF"
                                           VerticalAlignment="Center" Margin="0 0 8 0"/>
                                <ComboBox x:Name="QualityCombo" SelectedIndex="0" Width="100">
                                    <ComboBoxItem Content="1080p"/>
                                    <ComboBoxItem Content="720p"/>
                                    <ComboBoxItem Content="480p"/>
                                </ComboBox>
                            </StackPanel>

                            <!-- Row 1: Output + Max/From/To -->
                            <StackPanel Orientation="Horizontal" Grid.Row="1" Grid.Column="0">
                                <TextBlock Text="Output:" Foreground="#9CA3AF"
                                           VerticalAlignment="Center" Margin="0 0 8 0"/>
                                <TextBox x:Name="OutputDirTextBox" Width="200" Padding="6 4"/>
                                <Button x:Name="BrowseButton" Content="..."
                                        Style="{StaticResource SecondaryButton}"
                                        Width="28" Height="28" Margin="4 0 24 0" Padding="0"
                                        FontSize="12" FontWeight="Bold"
                                        Background="#25253D" Foreground="#7C3AED"
                                        BorderBrush="#3D3D6B"
                                        Click="BrowseButton_Click"/>
                                <TextBlock Text="Max:" Foreground="#9CA3AF"
                                           VerticalAlignment="Center" Margin="0 0 6 0"/>
                                <TextBox x:Name="MaxConcurrentText" Text="3" Width="36"
                                         Padding="4 4" HorizontalContentAlignment="Center"
                                         Margin="0 0 16 0"/>
                                <TextBlock Text="From:" Foreground="#9CA3AF"
                                           VerticalAlignment="Center" Margin="0 0 4 0"/>
                                <TextBox x:Name="FromRangeText" Width="40"
                                         Padding="4 4" HorizontalContentAlignment="Center"
                                         Margin="0 0 12 0"/>
                                <TextBlock Text="To:" Foreground="#9CA3AF"
                                           VerticalAlignment="Center" Margin="0 0 4 0"/>
                                <TextBox x:Name="ToRangeText" Width="40"
                                         Padding="4 4" HorizontalContentAlignment="Center"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Episode list -->
                    <Border Grid.Row="2" Background="#111122" BorderBrush="#2D2D4A"
                            BorderThickness="1" CornerRadius="12" Padding="14" Margin="0 0 0 10">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Grid Grid.Row="0" Margin="0 0 8 8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock x:Name="EpisodeCountText"
                                           Text="Episodes" Foreground="#9CA3AF" FontSize="13"
                                           VerticalAlignment="Center" Grid.Column="0"/>
                                <StackPanel Orientation="Horizontal" Grid.Column="2">
                                    <Button Content="Select All"
                                            Style="{StaticResource SecondaryButton}"
                                            Margin="0 0 6 0"
                                            Click="SelectAllButton_Click"/>
                                    <Button Content="Deselect All"
                                            Style="{StaticResource SecondaryButton}"
                                            Click="DeselectAllButton_Click"/>
                                </StackPanel>
                            </Grid>
                            <ListView x:Name="EpisodeListView" Grid.Row="1">
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal">
                                            <CheckBox IsChecked="{Binding IsSelected}"
                                                      Checked="EpisodeCheckChanged"
                                                      Unchecked="EpisodeCheckChanged"
                                                      Foreground="#22D3EE" Margin="4 2"/>
                                            <TextBlock Text="{Binding DisplayText}"
                                                       Foreground="#F5F7FA" FontSize="13"
                                                       Margin="4 2"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </Grid>
                    </Border>

                    <!-- Download button -->
                    <Button x:Name="DownloadButton" Grid.Row="3"
                            Content="Download Selected Episodes"
                            Style="{StaticResource PrimaryButton}"
                            FontSize="15" Padding="0 16"
                            Height="48" Margin="0 4 0 0"
                            IsEnabled="False"
                            Click="DownloadButton_Click"/>
                </Grid>
            </TabItem>

            <!-- ===== Downloads Tab ===== -->
            <TabItem Header="Downloads">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Toolbar -->
                    <Border Grid.Row="0" Background="#111122" BorderBrush="#2D2D4A"
                            BorderThickness="1" CornerRadius="12" Padding="14"
                            Margin="16 16 16 0">
                        <Grid>
                            <TextBlock Text="Download Jobs" Foreground="#F5F7FA"
                                       FontSize="14" FontWeight="SemiBold"
                                       VerticalAlignment="Center"/>
                            <Button x:Name="ClearAllButton"
                                    Content="Clear All Completed"
                                    Style="{StaticResource SecondaryButton}"
                                    HorizontalAlignment="Right"
                                    Click="ClearAllCompleted_Click"/>
                        </Grid>
                    </Border>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl x:Name="DownloadJobsControl"
                                      ItemTemplate="{StaticResource JobCardTemplate}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Margin="16 16 16 0"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                        </ItemsControl>
                    </ScrollViewer>

                    <TextBlock x:Name="NoDownloadsText"
                               Text="No downloads yet. Go to Browse to start one."
                               Foreground="#9CA3AF" FontSize="14"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Grid>
            </TabItem>

            <!-- ===== Settings Tab ===== -->
            <TabItem Header="Settings">
                <Grid Margin="16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Server Configuration" Foreground="#F5F7FA"
                               FontSize="16" FontWeight="SemiBold" Margin="0 0 0 12"/>

                    <Border Grid.Row="1" Background="#111122" BorderBrush="#2D2D4A"
                            BorderThickness="1" CornerRadius="12" Padding="14">
                        <TextBox x:Name="ConfigTextBox"
                                 Background="#09090B" Foreground="#F5F7FA"
                                 BorderBrush="#2D2D4A"
                                 AcceptsReturn="True" FontFamily="Consolas"
                                 FontSize="12" Padding="8"
                                 VerticalScrollBarVisibility="Auto"/>
                    </Border>

                    <Button x:Name="SaveConfigButton" Grid.Row="2"
                            Content="Save Configuration" Margin="0 12 0 0"
                            Style="{StaticResource PrimaryButton}"
                            HorizontalAlignment="Right" Padding="24 12"
                            Click="SaveConfig_Click"/>
                </Grid>
            </TabItem>

            <!-- ===== Logs Tab ===== -->
            <TabItem Header="Logs">
                <Grid Margin="16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Toolbar -->
                    <Border Grid.Row="0" Background="#111122" BorderBrush="#2D2D4A"
                            BorderThickness="1" CornerRadius="12" Padding="14"
                            Margin="0 0 0 10">
                        <Grid>
                            <TextBlock Text="Activity Log" Foreground="#F5F7FA"
                                       FontSize="14" FontWeight="SemiBold"
                                       VerticalAlignment="Center"/>
                            <Button x:Name="ClearLogButton"
                                    Content="Clear"
                                    Style="{StaticResource SecondaryButton}"
                                    HorizontalAlignment="Right"
                                    Click="ClearLog_Click"/>
                        </Grid>
                    </Border>

                    <!-- Log entries -->
                    <Border Grid.Row="1" Background="#111122" BorderBrush="#2D2D4A"
                            BorderThickness="1" CornerRadius="12" Padding="10">
                        <ListView x:Name="LogListView" Background="Transparent"
                                  BorderThickness="0"
                                  VirtualizingPanel.ScrollUnit="Item">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding DisplayText}"
                                               Foreground="{Binding TextColor}"
                                               FontFamily="Consolas"
                                               FontSize="11"
                                               Padding="4 2"/>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Border>
                </Grid>
            </TabItem>
        </TabControl>

        <!-- Status Bar -->
        <StatusBar Grid.Row="2" Padding="16 6">
            <TextBlock x:Name="StatusText" Text="Ready" FontSize="12" Foreground="#9CA3AF"/>
        </StatusBar>
    </Grid>
</Window>
